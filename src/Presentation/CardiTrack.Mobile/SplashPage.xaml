<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CardiTrack.Mobile.SplashPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource White}">

    <Grid>
        <!-- ── Gradient background (pre-rendered SVG with blurred ellipses) ── -->
        <Image Source="gradient_splash_bg.svg"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <!-- ── Loading state (default) ── -->
        <!-- Figma M1-01 A: logo centered (~50%), spinner near bottom (~88%) -->
        <Grid x:Name="LoadingPanel"
              RowDefinitions="*,Auto,80"
              Padding="24,0">

            <!-- Centered logo icon -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource White}"
                    WidthRequest="88" HeightRequest="88"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="17"/>
                </Border.StrokeShape>
                <Image Source="carditrack_logo.png"
                       WidthRequest="79" HeightRequest="68"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Loading spinner near bottom -->
            <ActivityIndicator Grid.Row="1"
                               IsRunning="True"
                               Color="{StaticResource White}"
                               HeightRequest="32" WidthRequest="32"
                               HorizontalOptions="Center" />
        </Grid>

        <!-- ── Error state (hidden by default) ── -->
        <!-- Figma M1-01 B: logo + wordmark upper-centre (~y454/512),
             error message + button pinned to the bottom (~y823/851) -->
        <Grid x:Name="ErrorPanel"
              IsVisible="False"
              RowDefinitions="*,Auto,*,Auto,Auto"
              RowSpacing="0"
              Padding="28,0">

            <!-- Logo + app name (upper-centre) -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="12"
                                 HorizontalOptions="Center">
                <Border BackgroundColor="{StaticResource White}"
                        WidthRequest="88" HeightRequest="88"
                        HorizontalOptions="Center"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="17"/>
                    </Border.StrokeShape>
                    <Image Source="carditrack_logo.png"
                           WidthRequest="79" HeightRequest="68"
                           Aspect="AspectFit"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <Label Text="CardiTrack"
                       Style="{StaticResource Heading1White}"
                       HorizontalTextAlignment="Center">
                    <Label.Shadow>
                        <Shadow Brush="#A0174E86" Offset="0,2" Radius="7"/>
                    </Label.Shadow>
                </Label>
            </VerticalStackLayout>

            <!-- Error message + retry button (pinned to bottom) -->
            <VerticalStackLayout Grid.Row="3"
                                 Spacing="0">
                <Label Text="Hmm, something didn't work."
                       Style="{StaticResource Body1SemiBold}"
                       Opacity="0.9"
                       HorizontalTextAlignment="Center" />

                <Button Text="Start Free 30-Day Trial"
                        Style="{StaticResource SecondaryOutlineButton}"
                        MaximumWidthRequest="332"
                        HorizontalOptions="Center"
                        Margin="0,16,0,0"
                        Clicked="OnRetryClicked" />
            </VerticalStackLayout>

            <!-- Bottom padding -->
            <BoxView Grid.Row="4" HeightRequest="28" Color="Transparent" />
        </Grid>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Name="RootPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CardiTrack.Mobile"
             x:Class="CardiTrack.Mobile.WelcomePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource White}">

    <ScrollView>
    <Grid RowDefinitions="Auto,Auto,Auto,16,Auto">

        <!-- ── Carousel (Figma mask-group composites, 440×571) ── -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                HeightRequest="571"
                HorizontalOptions="Fill">
            <CarouselView x:Name="SlideCarousel"
                          HeightRequest="571"
                          ItemsSource="{Binding Source={x:Reference RootPage}, Path=Slides}"
                          Loop="False"
                          IsScrollAnimated="True"
                          HorizontalOptions="Fill"
                          VerticalOptions="Fill">
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="local:WelcomeSlide">
                        <Image Source="{Binding HeroImage}"
                               Aspect="AspectFill"
                               HorizontalOptions="Fill"
                               VerticalOptions="Fill" />
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
        </Border>

        <!-- ── Header overlay (logo + sign-up, Figma y55/y68) ── -->
        <Grid Grid.Row="0"
              Padding="{OnPlatform Android='20,48,20,0',
                                   iOS='20,55,20,0',
                                   WinUI='20,24,20,0',
                                   Default='20,24,20,0'}"
              ColumnDefinitions="Auto,*"
              VerticalOptions="Start"
              InputTransparent="False">

            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource White}"
                    WidthRequest="46" HeightRequest="46"
                    StrokeThickness="0"
                    VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="9"/>
                </Border.StrokeShape>
                <Image Source="carditrack_logo.png"
                       WidthRequest="37" HeightRequest="32"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Label Grid.Column="1"
                   Text="Sign up"
                   FontFamily="QuicksandSemiBold"
                   FontSize="16"
                   TextColor="{StaticResource White}"
                   TextDecorations="Underline"
                   HorizontalOptions="End"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSignUpTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- ── Title (Figma y591) ── -->
        <Label x:Name="SlideTitle"
               Grid.Row="1"
               Style="{StaticResource Heading1}"
               HorizontalTextAlignment="Center"
               LineBreakMode="WordWrap"
               Margin="24,20,24,0" />

        <!-- ── Subtitle (per-slide top margin from Figma) ── -->
        <Label x:Name="SlideSubtitle"
               Grid.Row="2"
               Style="{StaticResource BodySubtitle}"
               Margin="40,16,40,0" />

        <!-- Row 3: fixed 16px spacer prevents bottom chrome overlapping subtitle -->

        <!-- ── Bottom area (Figma y743+) ── -->
        <VerticalStackLayout Grid.Row="4"
                             Spacing="0"
                             Padding="20,0,20,28">

            <!-- Pill indicators (active 32×8, inactive 8×8) -->
            <HorizontalStackLayout x:Name="IndicatorPanel"
                                   HorizontalOptions="Center"
                                   Spacing="8"
                                   Margin="0,0,0,0">
                <BoxView x:Name="Ind0" WidthRequest="32" HeightRequest="8"
                         CornerRadius="4" Color="{StaticResource ActiveIndicator}"/>
                <BoxView x:Name="Ind1" WidthRequest="8" HeightRequest="8"
                         CornerRadius="4" Color="{StaticResource InactiveIndicator}"/>
                <BoxView x:Name="Ind2" WidthRequest="8" HeightRequest="8"
                         CornerRadius="4" Color="{StaticResource InactiveIndicator}"/>
            </HorizontalStackLayout>

            <!-- CTA (Button 5 — 332×52, inset highlight) -->
            <Border x:Name="CtaBorder"
                    Background="{StaticResource GradientButtonBrush}"
                    StrokeThickness="0"
                    HeightRequest="52"
                    HorizontalOptions="Fill"
                    Margin="34,30,34,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#8FFFFFFF" Offset="2,2" Radius="5"/>
                </Border.Shadow>
                <Grid>
                    <BoxView Color="#8FFFFFFF"
                             WidthRequest="120"
                             HeightRequest="18"
                             CornerRadius="9"
                             HorizontalOptions="Start"
                             VerticalOptions="Start"
                             Margin="12,6,0,0"
                             InputTransparent="True"/>
                    <Label Text="Start Free 30-Day Trial"
                           FontFamily="Quicksand"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="{StaticResource White}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCtaTapped"/>
                </Border.GestureRecognizers>
            </Border>

            <!-- Pricing disclaimer (Figma y849) -->
            <Label Text="Then $8/month - Cancel anytime"
                   Style="{StaticResource Body2}"
                   HorizontalTextAlignment="Center"
                   Margin="0,16,0,0" />

            <!-- Terms & Privacy (Figma y901) -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="0"
                                   Margin="0,30,0,0">
                <Label Text="By continuing, you agree to "
                       Style="{StaticResource Body2}"
                       VerticalTextAlignment="Center" />
                <Label Text="Terms &amp; Privacy"
                       TextColor="{StaticResource Primary}"
                       FontFamily="QuicksandSemiBold"
                       FontSize="14"
                       TextDecorations="Underline"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTermsTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
    </ScrollView>
</ContentPage>
